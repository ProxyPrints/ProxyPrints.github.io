{
  "title": "Artist Consensus Response",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "resolvedArtist": { "$ref": "../CanonicalArtist.json" },
    "isUnknown": { "type": "boolean" },
    "voteTally": {
      "type": "array",
      "items": { "$ref": "../ArtistVoteTallyEntry.json" }
    }
  },
  "required": ["isUnknown", "voteTally"],
  "additionalProperties": false
}
